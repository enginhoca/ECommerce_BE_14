{
  "info": {
    "name": "ECommerce.API - Complete Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection generated from provided openapi.json. Uses {{baseUrl}} and {{bearerToken}} environment variables."
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"userName\": \"testuser123\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"P@ssw0rd!\",\n  \"confirmPassword\": \"P@ssw0rd!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}api/Auth/register",
              "protocol": "http",
              "host": ["ecommerce-be-14-ugrt.onrender.com"],
              "path": ["api", "Auth", "register"]
            },
            "description": "Register a new user."
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userNameOrEmail\": \"testuser@example.com\",\n  \"password\": \"P@ssw0rd!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}api/Auth/login",
              "protocol": "http",
              "host": ["ecommerce-be-14-ugrt.onrender.com"],
              "path": ["api", "Auth", "login"]
            },
            "description": "Login. Successful response is expected to include a token in `data.token`, `data.accessToken`, `token`, or `accessToken`. Test script extracts and saves it to environment variable `bearerToken`."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// try to parse response and set bearer token if present",
                  "var json = {};",
                  "try { json = pm.response.json(); } catch (e) { json = {}; }",
                  "var token = (json.data && (json.data.token || json.data.accessToken)) || json.token || json.accessToken || '';",
                  "if (token) { pm.environment.set('bearerToken', token); pm.test('Saved bearerToken to environment', function(){ pm.expect(token).to.not.be.empty; }); } else { pm.test('No token found in response', function(){ pm.expect(token).to.not.be.empty; }); }"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{bearerToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}api/Auth/profile",
              "protocol": "http",
              "host": ["ecommerce-be-14-ugrt.onrender.com"],
              "path": ["api", "Auth", "profile"]
            },
            "description": "Get profile of authenticated user. Make sure `bearerToken` is set (from Login)."
          },
          "response": []
        }
      ]
    },
    {
