            "url": { "raw": "{{baseUrl}}api/Categories/:id", "protocol": "http", "host": ["ecommerce-be-14-ugrt.onrender.com"], "path": ["api","Categories",":id"], "variable": [{ "key": "id", "value": "1" }] }
